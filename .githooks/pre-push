#!/bin/bash
# 𓁟 Thoth (sirsi-thoth) Pre-Push Gate
# Runs simple smoke test, so broken code never reaches the registry.
# Install: git config core.hooksPath .githooks
# Skip:    git push --no-verify (use sparingly)

set -e

echo ""
echo "  𓁟 Thoth (sirsi-thoth) pre-push gate..."
echo ""

# 1. Smoke test
if ! node index.js --help >/dev/null; then
    echo "  ❌ smoke test failed — index.js --help is broken"
    exit 1
fi

echo "  ✅ Pipeline gate passed — pushing to the registry"
echo ""
